{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiagramGraph",
  "description": "Schema for a flowchart graph",
  "type": "object",
  "properties": {
    "diagram_type": {
      "type": "string",
      "description": "The type of diagram"
    },
    "nodes": {
      "type": "array",
      "items": {
        "properties": {
          "bounding_box": {
            "anyOf": [
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Node bounding_box",
            "title": "Bounding Box"
          },
          "confidence": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Node confidence",
            "title": "Confidence"
          },
          "label": {
            "description": "Node label",
            "title": "Label",
            "type": "string"
          },
          "id": {
            "description": "Node id",
            "title": "Id",
            "type": "string"
          },
          "shape": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Node shape",
            "title": "Shape"
          }
        },
        "required": [
          "label",
          "id"
        ],
        "title": "GraphNode",
        "type": "object"
      },
      "description": "List of graph nodes"
    },
    "edges": {
      "type": "array",
      "items": {
        "properties": {
          "label": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Edge label",
            "title": "Label"
          },
          "id": {
            "description": "Edge id",
            "title": "Id",
            "type": "string"
          },
          "source": {
            "description": "Edge source",
            "title": "Source",
            "type": "string"
          },
          "confidence": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Edge confidence",
            "title": "Confidence"
          },
          "target": {
            "description": "Edge target",
            "title": "Target",
            "type": "string"
          }
        },
        "required": [
          "id",
          "source",
          "target"
        ],
        "title": "GraphEdge",
        "type": "object"
      },
      "description": "List of graph edges"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata about the graph"
    }
  },
  "required": [
    "diagram_type",
    "nodes",
    "edges"
  ]
}