# GCP — Core project settings
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=statmike-mlops-349915
GOOGLE_CLOUD_LOCATION=us-central1

# Models — LLM used for agent reasoning and reranker tool calls
AGENT_MODEL=gemini-3.1-flash-preview
TOOL_MODEL=gemini-3.1-flash-lite-preview

# BigQuery — Location for dataset creation (multi-region)
BQ_LOCATION=US

# Dataplex — Location for DataScan (requires regional, not multi-region)
DATAPLEX_LOCATION=us-central1

# Reranker — Default number of top tables to return
TOP_K=5

# Resource prefix — All datasets use this prefix
RESOURCE_PREFIX=bigquery_context
