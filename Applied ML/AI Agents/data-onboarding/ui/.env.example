# GCP — project and region
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Agent mode — "local" runs the agent in-process via ADK Runner,
# "agent_engine" calls the deployed agent on Vertex AI.
# Local mode requires running from the main project venv (not ui/).
AGENT_MODE=local

# Agent Engine — deployed chat agent resource ID
# Only needed when AGENT_MODE=agent_engine
# Find this with: uv run python deploy/deploy.py chat --info
AGENT_ENGINE_RESOURCE_ID=your-resource-id

# Server
HOST=0.0.0.0
PORT=8080

# Voice mode — model for Live API (used by /ws/voice endpoint)
VOICE_MODEL=gemini-live-2.5-flash-native-audio

# Logging — DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
