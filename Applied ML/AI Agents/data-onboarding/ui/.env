# GCP
GOOGLE_CLOUD_PROJECT=statmike-mlops-349915
GOOGLE_CLOUD_LOCATION=us-central1

# Agent mode — "local" (ADK Runner) or "agent_engine" (deployed)
AGENT_MODE=agent_engine

# Agent Engine — deployed chat agent (used when AGENT_MODE=agent_engine)
AGENT_ENGINE_RESOURCE_ID=4403271940115005440

# Chat scope — restrict agent to CBOE tables only
CHAT_SCOPE=data_onboarding_datashop_cboe_com_bronze

# Conversational Analytics API — Thinking mode (THINKING or FAST)
CONVO_THINKING_MODE=FAST

# Server
HOST=0.0.0.0
PORT=8080
