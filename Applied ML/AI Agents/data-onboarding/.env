# GCP — Core project settings
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=statmike-mlops-349915
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_STORAGE_BUCKET=gs://statmike-mlops-349915

# Models — LLM used for agent reasoning and tool calls (e.g., cross_reference, propose_columns).
# Set AGENT_MODEL_LOCATION or TOOL_MODEL_LOCATION to override the default region for API calls.
AGENT_MODEL=gemini-2.5-flash
#AGENT_MODEL=gemini-3-flash-preview
AGENT_MODEL_LOCATION=global  # Overrides GOOGLE_CLOUD_LOCATION for the agent API endpoint
TOOL_MODEL=gemini-2.5-pro
#TOOL_MODEL=gemini-3.1-pro-preview
TOOL_MODEL_LOCATION=global  # Uncomment for preview models; overrides GOOGLE_CLOUD_LOCATION for tool calls

# Dataplex — Location for Dataplex data profile scans.
# Defaults to GOOGLE_CLOUD_LOCATION. Override if your Dataplex lake is in a different region.
# DATAPLEX_LOCATION=us-central1

# Naming — All BQ datasets and GCS paths derive from RESOURCE_PREFIX.
# Override any individual name by uncommenting and setting it explicitly.
# For URL sources, the domain slug is extracted automatically (e.g., data.cms.gov → cms_gov).
# Multiple URLs from the same domain share the same bronze and staging datasets.
#
# Dataset layout per domain:
#   {RESOURCE_PREFIX}_{domain}_staging    → external tables (ext_*) pointing to GCS
#   {RESOURCE_PREFIX}_{domain}_bronze     → materialized tables + table_documentation + data_catalog
#   {RESOURCE_PREFIX}_meta                → shared metadata (lineage, decisions, manifests)
#   {RESOURCE_PREFIX}_adk                 → ADK agent analytics
RESOURCE_PREFIX=data_onboarding
# BQ_BRONZE_DATASET={RESOURCE_PREFIX}_bronze                          → data_onboarding_bronze (fallback for GCS sources)
# BQ_META_DATASET={RESOURCE_PREFIX}_meta                              → data_onboarding_meta (shared across domains)
# BQ_ANALYTICS_DATASET={RESOURCE_PREFIX}_adk                          → data_onboarding_adk
# BQ_ANALYTICS_TABLE=agent_events                                     (static)
# GCS_STAGING_ROOT=applied-ml/ai-agents/{RESOURCE_PREFIX with _ → -}  → applied-ml/ai-agents/data-onboarding

# BigQuery — Location for dataset creation. All metadata and bronze datasets use this.
BQ_DATASET_LOCATION=US

# Web Crawling — Controls how crawl_url discovers pages and files from a starting URL.
# CRAWL_SAME_ORIGIN_ONLY: When true, only follow links to the same hostname as the starting URL.
#   Set to false to allow cross-origin crawling (use with caution — may discover many unrelated files).
# CRAWL_MAX_DEPTH: How many link hops from the starting URL. 0 = starting page only, 1 = follow one
#   level of links, etc. Higher values increase crawl time and may find irrelevant content.
# CRAWL_MAX_FILES: Hard cap on total downloadable files discovered. Prevents runaway crawls.
# ACQUIRE_FILE_EXTENSIONS: File extensions that crawl_url recognizes as downloadable. URLs whose
#   path ends with one of these extensions are added to the file list; others are treated as pages.
#   zip is included so archives are downloaded; their contents are extracted during download.
CRAWL_SAME_ORIGIN_ONLY=true
CRAWL_MAX_DEPTH=1
CRAWL_MAX_FILES=200
ACQUIRE_FILE_EXTENSIONS=csv,tsv,json,jsonl,xlsx,xls,parquet,avro,orc,xml,pdf,txt,md,html,zip

# File Classification — Controls how classify_files categorizes staged files.
# DATA_FILE_EXTENSIONS: Extensions treated as structured data files → ingested into BQ tables.
# CONTEXT_FILE_EXTENSIONS: Extensions treated as documentation/context → used for column descriptions
#   and cross-referencing but NOT loaded as BQ tables.
# Note: PDF is in CONTEXT_FILE_EXTENSIONS only (not DATA). PDFs are used for context (e.g., data
#   dictionaries, documentation) and are never treated as tabular data sources. Files in the
#   context/ subdirectory are always classified as context regardless of extension.
DATA_FILE_EXTENSIONS=csv,tsv,json,jsonl,xlsx,xls,parquet,avro,orc,xml
CONTEXT_FILE_EXTENSIONS=pdf,txt,md,html

# Output — Directory for generated output files (changelog, etc.).
OUTPUT_DIR=./output

# Deployment (Agent Engine) — Uncomment to enable OpenTelemetry tracing for deployed agents.
# GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
