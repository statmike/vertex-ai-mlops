# Required
GOOGLE_CLOUD_PROJECT=statmike-mlops-349915
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Agent model — used for agent reasoning and routing
AGENT_MODEL=gemini-3-flash-preview
AGENT_MODEL_LOCATION=global

# Tool model — used for tool-calling agents (can be different for cost/latency tradeoffs)
TOOL_MODEL=gemini-3-flash-preview
TOOL_MODEL_LOCATION=global
