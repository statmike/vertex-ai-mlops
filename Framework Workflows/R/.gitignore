# Local Python environment (uv)
.venv/

# Large binary model fetched from GCS and trimmed at build time — not source.
# Regenerated whenever the serving notebook builds its container.
model.rds

# Note: plumber.R, serve.R, Dockerfile, and the compiled pipeline YAMLs
